<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 阴影 -->
    <item android:bottom="4dp" android:left="2dp" android:right="2dp" android:top="2dp">
        <shape>
            <solid android:color="@color/glass_shadow" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- 玻璃背景 -->
    <item>
        <shape>
            <solid android:color="@color/glass_background" />
            <corners android:radius="16dp" />
            <stroke android:width="0.5dp" android:color="@color/glass_border" />
        </shape>
    </item>
</layer-list>