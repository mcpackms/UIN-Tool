<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/spacing_sm">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_md"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:hintEnabled="true">

        <EditText
            android:id="@+id/et_plugin_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/plugin_field_id"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_md"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:hintEnabled="true">

        <EditText
            android:id="@+id/et_plugin_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/plugin_field_name"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_md"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:hintEnabled="true">

        <EditText
            android:id="@+id/et_plugin_author"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/plugin_field_author"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_md"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:hintEnabled="true">

        <EditText
            android:id="@+id/et_plugin_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/plugin_field_description"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:maxLines="5"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" />

    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/spacing_md"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:hintEnabled="true">

            <EditText
                android:id="@+id/et_plugin_version"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/plugin_field_version"
                android:inputType="number"
                android:text="1"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:hintEnabled="true">

            <EditText
                android:id="@+id/et_plugin_version_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/plugin_field_version_name"
                android:text="1.0.0"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:hintEnabled="true">

        <EditText
            android:id="@+id/et_main_class"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/plugin_field_main_class"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" />

    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>