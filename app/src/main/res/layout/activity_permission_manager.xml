<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_toolbar"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@android:color/white"
        app:title="@string/title_permission_manager" />

    <!-- 按钮网格布局 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <LinearLayout style="@style/ButtonGridRow">
            <!-- 一键授权按钮 -->
            <LinearLayout
                android:id="@+id/btn_grant_all_container"
                style="@style/FlatButtonContainer"
                android:layout_marginEnd="@dimen/spacing_md">
                <ImageView
                    style="@style/FlatButtonIcon"
                    android:src="@drawable/ic_check_all"
                    android:tint="@color/primary" />
                <TextView
                    style="@style/FlatButtonText"
                    android:text="@string/btn_grant_all" />
            </LinearLayout>

            <!-- 刷新状态按钮 -->
            <LinearLayout
                android:id="@+id/btn_refresh_container"
                style="@style/FlatButtonContainer"
                android:layout_marginStart="@dimen/spacing_md">
                <ImageView
                    style="@style/FlatButtonIcon"
                    android:src="@drawable/ic_refresh"
                    android:tint="@color/info" />
                <TextView
                    style="@style/FlatButtonText"
                    android:text="@string/refresh" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout style="@style/ButtonGridRow">
            <!-- 插件权限按钮 -->
            <LinearLayout
                android:id="@+id/btn_plugin_permission_container"
                style="@style/FlatButtonContainer"
                android:layout_marginEnd="@dimen/spacing_md">
                <ImageView
                    style="@style/FlatButtonIcon"
                    android:src="@drawable/ic_extension"
                    android:tint="@color/warning" />
                <TextView
                    style="@style/FlatButtonText"
                    android:text="@string/btn_plugin_permission" />
            </LinearLayout>

            <!-- 占位（保持网格对齐） -->
            <LinearLayout
                style="@style/FlatButtonContainer"
                android:layout_marginStart="@dimen/spacing_md"
                android:visibility="invisible" />
        </LinearLayout>

    </LinearLayout>

    <!-- 权限列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/permissionRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="@dimen/spacing_md"
        android:clipToPadding="false" />

</LinearLayout>