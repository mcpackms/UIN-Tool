<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/spacing_lg">

    <!-- 颜色预览 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="颜色预览"
        style="@style/TextCaption"
        android:textColor="@color/text_hint"
        android:gravity="center"
        android:layout_marginBottom="@dimen/spacing_sm" />

    <View
        android:id="@+id/color_preview"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/primary"
        android:layout_marginBottom="@dimen/spacing_lg" />

    <!-- 红色 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="红色 (R)"
        style="@style/TextCaption"
        android:textColor="@color/error"
        android:layout_marginBottom="@dimen/spacing_xxs" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/spacing_md">

        <SeekBar
            android:id="@+id/seek_bar_red"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:progressDrawable="@drawable/bg_progress" />

        <TextView
            android:id="@+id/tv_red_value"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/error"
            android:gravity="end" />

    </LinearLayout>

    <!-- 绿色 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="绿色 (G)"
        style="@style/TextCaption"
        android:textColor="@color/success"
        android:layout_marginBottom="@dimen/spacing_xxs" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/spacing_md">

        <SeekBar
            android:id="@+id/seek_bar_green"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:progressDrawable="@drawable/bg_progress" />

        <TextView
            android:id="@+id/tv_green_value"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/success"
            android:gravity="end" />

    </LinearLayout>

    <!-- 蓝色 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="蓝色 (B)"
        style="@style/TextCaption"
        android:textColor="@color/info"
        android:layout_marginBottom="@dimen/spacing_xxs" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/spacing_md">

        <SeekBar
            android:id="@+id/seek_bar_blue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:progressDrawable="@drawable/bg_progress" />

        <TextView
            android:id="@+id/tv_blue_value"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/info"
            android:gravity="end" />

    </LinearLayout>

    <!-- 透明度 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="透明度 (A)"
        style="@style/TextCaption"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="@dimen/spacing_xxs" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/spacing_lg">

        <SeekBar
            android:id="@+id/seek_bar_alpha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:progressDrawable="@drawable/bg_progress" />

        <TextView
            android:id="@+id/tv_alpha_value"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="255"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/text_secondary"
            android:gravity="end" />

    </LinearLayout>

    <!-- 十六进制颜色 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="颜色值："
            style="@style/TextBody"
            android:layout_marginEnd="@dimen/spacing_sm" />

        <EditText
            android:id="@+id/et_hex_color"
            android:layout_width="0dp"
            android:layout_height="@dimen/input_height"
            android:layout_weight="1"
            android:hint="#RRGGBB 或 #AARRGGBB"
            android:inputType="text"
            android:maxLines="1"
            android:padding="@dimen/spacing_md"
            android:background="@drawable/bg_input"
            android:textSize="@dimen/text_caption" />

    </LinearLayout>

</LinearLayout>