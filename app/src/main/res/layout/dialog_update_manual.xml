<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:maxHeight="400dp">

    <!-- 标题区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_lg"
        android:gravity="center_vertical"
        android:background="@color/primary">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚠️ 检查更新失败"
            android:textSize="@dimen/text_title"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 可滚动的内容区域 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <TextView
                android:id="@+id/tv_error_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="无法检查更新"
                style="@style/TextBody"
                android:lineSpacingExtra="@dimen/spacing_sm" />

        </LinearLayout>

    </ScrollView>

    <!-- 按钮区域 - 横向排列，支持两行文字 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingBottom="@dimen/spacing_lg"
        android:gravity="center">

        <Button
            android:id="@+id/btn_go_download"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="前往下载\n\n"
            android:lines="2"
            android:maxLines="2"
            android:minLines="2"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            style="@style/Widget.UIN.Tool.Button"
            android:layout_marginEnd="@dimen/spacing_sm" />

        <Button
            android:id="@+id/btn_enter_app"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="进入应用\n\n"
            android:lines="2"
            android:maxLines="2"
            android:minLines="2"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            style="@style/Widget.UIN.Tool.Button.Outlined"
            android:layout_marginStart="@dimen/spacing_sm" />

    </LinearLayout>

</LinearLayout>