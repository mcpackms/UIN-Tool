<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:maxHeight="480dp">

    <!-- 标题区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_lg"
        android:gravity="center_vertical"
        android:background="@color/primary">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📱 发现新版本"
            android:textSize="@dimen/text_title"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 可滚动的内容区域 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical"
        android:fillViewport="true"
        android:paddingBottom="@dimen/spacing_sm">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- 版本信息标题 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📌 版本信息"
                style="@style/TextSubtitle"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <!-- 版本名称 -->
            <TextView
                android:id="@+id/tv_version_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="版本号："
                style="@style/TextBody"
                android:layout_marginBottom="@dimen/spacing_xxs" />

            <!-- 版本代码 -->
            <TextView
                android:id="@+id/tv_version_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="版本代码："
                style="@style/TextBody"
                android:layout_marginBottom="@dimen/spacing_xxs" />

            <!-- 发布日期 -->
            <TextView
                android:id="@+id/tv_release_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="发布日期："
                style="@style/TextBody"
                android:layout_marginBottom="@dimen/spacing_xxs" />

            <!-- 文件大小 -->
            <TextView
                android:id="@+id/tv_file_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="文件大小："
                style="@style/TextBody"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginVertical="@dimen/spacing_md" />

            <!-- 更新内容标题 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📝 更新内容"
                style="@style/TextSubtitle"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <!-- 更新内容 - WebView 显示 Markdown -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@color/surface_variant">

                <WebView
                    android:id="@+id/wv_release_notes"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <ProgressBar
                    android:id="@+id/progress_webview"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:visibility="gone" />

            </FrameLayout>

            <!-- 提示文字 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="请选择更新方式："
                style="@style/TextBody"
                android:textStyle="bold"
                android:layout_marginTop="@dimen/spacing_md"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:textColor="@color/primary"
                android:gravity="center" />

        </LinearLayout>

    </ScrollView>

    <!-- 按钮区域 - 横向排列 -->
    <LinearLayout
        android:id="@+id/button_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingBottom="@dimen/spacing_lg"
        android:gravity="center">

        <Button
            android:id="@+id/btn_auto_download"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="自动下载"
            android:lines="2"
            android:maxLines="2"
            android:minLines="2"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:textSize="11sp"
            style="@style/Widget.UIN.Tool.Button"
            android:layout_marginEnd="@dimen/spacing_sm" />

        <Button
            android:id="@+id/btn_manual_download"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="手动下载"
            android:lines="2"
            android:maxLines="2"
            android:minLines="2"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:textSize="11sp"
            style="@style/Widget.UIN.Tool.Button.Outlined"
            android:layout_marginStart="@dimen/spacing_sm"
            android:layout_marginEnd="@dimen/spacing_sm" />

        <Button
            android:id="@+id/btn_ignore"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="暂不更新"
            android:lines="2"
            android:maxLines="2"
            android:minLines="2"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:textSize="11sp"
            style="@style/Widget.UIN.Tool.Button.Outlined"
            android:layout_marginStart="@dimen/spacing_sm" />

    </LinearLayout>

</LinearLayout>