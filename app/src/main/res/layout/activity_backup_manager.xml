<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_toolbar"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@android:color/white"
        app:title="@string/title_backup_manager" />

    <!-- 按钮网格布局 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <LinearLayout style="@style/ButtonGridRow">
            <!-- 备份全部按钮 -->
            <LinearLayout
                android:id="@+id/btn_backup_container"
                style="@style/FlatButtonContainer"
                android:layout_marginEnd="@dimen/spacing_md">
                <ImageView
                    style="@style/FlatButtonIcon"
                    android:src="@drawable/ic_backup"
                    android:tint="@color/primary" />
                <TextView
                    style="@style/FlatButtonText"
                    android:text="@string/btn_backup" />
            </LinearLayout>

            <!-- 恢复按钮 -->
            <LinearLayout
                android:id="@+id/btn_restore_container"
                style="@style/FlatButtonContainer"
                android:layout_marginStart="@dimen/spacing_md">
                <ImageView
                    style="@style/FlatButtonIcon"
                    android:src="@drawable/ic_restore"
                    android:tint="@color/warning" />
                <TextView
                    style="@style/FlatButtonText"
                    android:text="@string/btn_restore" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout style="@style/ButtonGridRow">
            <!-- 刷新按钮 -->
            <LinearLayout
                android:id="@+id/btn_refresh_container"
                style="@style/FlatButtonContainer"
                android:layout_marginEnd="@dimen/spacing_md">
                <ImageView
                    style="@style/FlatButtonIcon"
                    android:src="@drawable/ic_refresh"
                    android:tint="@color/info" />
                <TextView
                    style="@style/FlatButtonText"
                    android:text="@string/refresh" />
            </LinearLayout>

            <!-- 占位（保持网格对齐） -->
            <LinearLayout
                style="@style/FlatButtonContainer"
                android:layout_marginStart="@dimen/spacing_md"
                android:visibility="invisible" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:progressDrawable="@drawable/bg_progress"
            android:visibility="gone"
            android:layout_marginTop="@dimen/spacing_md" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/TextCaption"
            android:visibility="gone"
            android:padding="@dimen/spacing_sm" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/backup_list_title"
        style="@style/TextSubtitle"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingBottom="@dimen/spacing_sm" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="@dimen/spacing_md"
        android:clipToPadding="false" />

</LinearLayout>