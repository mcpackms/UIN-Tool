<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- 跳过按钮 -->
    <Button
        android:id="@+id/btn_skip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_margin="@dimen/spacing_md"
        android:text="@string/onboarding_skip"
        android:background="@android:color/transparent"
        android:textColor="@color/text_hint"
        android:textSize="12sp" />

    <!-- ViewPager2 -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- 点状指示器 - 使用 LinearLayout 手动控制 -->
    <LinearLayout
        android:id="@+id/indicator_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="@dimen/spacing_md"
        android:visibility="gone" />

    <!-- 按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_lg"
        android:gravity="center">

        <Button
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:text="@string/onboarding_next"
            style="@style/Widget.UIN.Tool.Button" />

        <Button
            android:id="@+id/btn_start"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:text="@string/onboarding_start"
            style="@style/Widget.UIN.Tool.Button"
            android:visibility="gone" />

    </LinearLayout>

    <!-- 底部链接区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:gravity="center">

        <TextView
            android:id="@+id/tv_doc_link"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="文档中心"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:padding="@dimen/spacing_sm"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="|"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:padding="@dimen/spacing_sm" />

        <TextView
            android:id="@+id/tv_permission_link"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="权限说明"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:padding="@dimen/spacing_sm"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />

    </LinearLayout>

</LinearLayout>