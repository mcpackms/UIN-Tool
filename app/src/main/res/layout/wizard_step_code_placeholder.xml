<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/spacing_lg"
    android:gravity="center">

    <ImageView
        android:layout_width="@dimen/icon_xxxlarge"
        android:layout_height="@dimen/icon_xxxlarge"
        android:src="@drawable/ic_code"
        android:tint="@color/primary"
        android:layout_marginBottom="@dimen/spacing_xl" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="代码编辑器"
        style="@style/TextHeadline"
        android:layout_marginBottom="@dimen/spacing_md" />

    <TextView
        android:id="@+id/tv_code_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="点击下方按钮打开编辑器"
        style="@style/TextBody"
        android:layout_marginBottom="@dimen/spacing_xl"
        android:gravity="center" />

    <Button
        android:id="@+id/btn_open_editor"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height_medium"
        android:text="打开代码编辑器"
        style="@style/Widget.UIN.Tool.Button" />

    <TextView
        android:id="@+id/tv_code_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xl"
        android:text=""
        style="@style/TextCaption"
        android:lineSpacingExtra="@dimen/spacing_sm" />

</LinearLayout>