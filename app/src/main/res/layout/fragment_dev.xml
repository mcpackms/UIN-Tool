<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/nav_dev"
            style="@style/TextDisplayLarge"
            android:layout_marginBottom="@dimen/spacing_xl" />

        <!-- 开发工具卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_lg"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding_medium">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <ImageView
                        android:layout_width="@dimen/icon_large"
                        android:layout_height="@dimen/icon_large"
                        android:src="@drawable/ic_developer_mode"
                        android:tint="@color/primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/developer_tools"
                        style="@style/TextTitle"
                        android:layout_marginStart="@dimen/spacing_md" />

                </LinearLayout>

                <Button
                    android:id="@+id/btn_create_plugin"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height_medium"
                    android:text="@string/btn_create_plugin"
                    style="@style/Widget.UIN.Tool.Button"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <Button
                    android:id="@+id/btn_export_template"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height_medium"
                    android:text="@string/btn_export_template"
                    style="@style/Widget.UIN.Tool.Button.Outlined"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <Button
                    android:id="@+id/btn_view_docs"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/button_height_small"
                    android:text="@string/btn_view_docs"
                    style="@style/Widget.UIN.Tool.Button.Text" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 快速开始卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding_medium">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <ImageView
                        android:layout_width="@dimen/icon_large"
                        android:layout_height="@dimen/icon_large"
                        android:src="@drawable/ic_info"
                        android:tint="@color/accent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/quick_start"
                        style="@style/TextTitle"
                        android:layout_marginStart="@dimen/spacing_md" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/quick_start_steps"
                    style="@style/TextCaption"
                    android:lineSpacingExtra="@dimen/spacing_xxs" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>