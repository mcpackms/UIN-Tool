<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_toolbar"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@android:color/white"
        app:title="@string/title_log_viewer" />

    <TextView
        android:id="@+id/tv_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_md"
        android:background="@color/warning"
        android:textColor="@android:color/black"
        android:textSize="@dimen/text_body"
        android:visibility="gone" />

    <!-- 按钮网格布局 2x2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <LinearLayout style="@style/ButtonGridRow">
            <LinearLayout
                android:id="@+id/btn_refresh_container"
                style="@style/FlatButtonContainer"
                android:layout_marginEnd="@dimen/spacing_md">
                <ImageView
                    style="@style/FlatButtonIcon"
                    android:src="@drawable/ic_refresh"
                    android:tint="@color/primary" />
                <TextView
                    style="@style/FlatButtonText"
                    android:text="@string/refresh" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_clear_container"
                style="@style/FlatButtonContainer"
                android:layout_marginStart="@dimen/spacing_md">
                <ImageView
                    style="@style/FlatButtonIcon"
                    android:src="@drawable/ic_delete"
                    android:tint="@color/error" />
                <TextView
                    style="@style/FlatButtonText"
                    android:text="@string/btn_clear_today" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout style="@style/ButtonGridRow">
            <LinearLayout
                android:id="@+id/btn_clear_all_container"
                style="@style/FlatButtonContainer"
                android:layout_marginEnd="@dimen/spacing_md">
                <ImageView
                    style="@style/FlatButtonIcon"
                    android:src="@drawable/ic_delete_sweep"
                    android:tint="@color/error" />
                <TextView
                    style="@style/FlatButtonText"
                    android:text="@string/btn_clear_all" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_export_container"
                style="@style/FlatButtonContainer"
                android:layout_marginStart="@dimen/spacing_md">
                <ImageView
                    style="@style/FlatButtonIcon"
                    android:src="@drawable/ic_export"
                    android:tint="@color/info" />
                <TextView
                    style="@style/FlatButtonText"
                    android:text="@string/export_action" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="@dimen/spacing_md"
        android:background="@color/surface_variant">

        <TextView
            android:id="@+id/tv_log_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/text_primary"
            android:lineSpacingExtra="2dp" />

    </ScrollView>

</LinearLayout>