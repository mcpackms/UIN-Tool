<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 统一扁平按钮容器样式 -->
    <style name="FlatButtonContainer">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">70dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/bg_button_flat</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>

    <!-- 统一扁平按钮图标样式 -->
    <style name="FlatButtonIcon">
        <item name="android:layout_width">@dimen/icon_large</item>
        <item name="android:layout_height">@dimen/icon_large</item>
        <item name="android:layout_marginBottom">@dimen/spacing_xs</item>
    </style>

    <!-- 统一扁平按钮文字样式 -->
    <style name="FlatButtonText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:maxLines">2</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- 统一网格行样式 -->
    <style name="ButtonGridRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:layout_marginBottom">@dimen/spacing_md</item>
    </style>

    <!-- 统一卡片内边距 -->
    <style name="CardPadding">
        <item name="android:padding">@dimen/card_padding_medium</item>
    </style>

    <!-- 统一卡片图标样式 -->
    <style name="CardIcon">
        <item name="android:layout_width">@dimen/icon_xlarge</item>
        <item name="android:layout_height">@dimen/icon_xlarge</item>
        <item name="android:layout_marginEnd">@dimen/spacing_md</item>
    </style>

    <!-- 统一卡片标题样式 -->
    <style name="CardTitle" parent="TextSubtitle">
        <item name="android:textStyle">bold</item>
    </style>

    <!-- 统一卡片描述样式 -->
    <style name="CardDesc" parent="TextCaption">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
</resources>